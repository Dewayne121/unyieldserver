# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Prisma)
# For Railway: Use the DATABASE_URL provided by Railway
# For local development: Use your local PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/unyielding?schema=public"

# Optional legacy MongoDB source for one-way user sync into PostgreSQL.
# In development, server auto-sync runs by default when this is set.
MONGODB_URI=
# Override auto-sync behavior explicitly.
# ENABLE_MONGO_USER_SYNC=true
# ENABLE_MONGO_USER_SYNC=false
# Only sync when PostgreSQL user count is below this threshold.
MONGO_USER_SYNC_THRESHOLD=20

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=12h
PASSWORD_MIN_LENGTH=10

# CORS (comma-separated allowlist, required in production web deployments)
# Supports exact origins and wildcard patterns using *.
# Example:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com,https://*.exp.direct
CORS_ORIGINS=

# Allow localhost and common tunnel origins (.loca.lt / .trycloudflare.com).
# Set to false to disable this convenience behavior.
ALLOW_DEV_TUNNEL_ORIGINS=true

# Optional explicit allowed headers list for CORS preflight.
# Leave empty to let cors reflect requested headers automatically.
# CORS_ALLOWED_HEADERS=Content-Type,Authorization,bypass-tunnel-reminder
CORS_ALLOWED_HEADERS=

# Enforce HTTPS redirects/rejections when behind a proxy (recommended true)
ENFORCE_HTTPS=true

# Oracle Cloud Object Storage (for video uploads)
# ORACLE_SECRET should be a base64 encoded JSON string with your Oracle credentials
ORACLE_SECRET=

# Google Cloud Vision API (for face blur feature)
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_API=

# Face Blur API (Python microservice)
# For local: http://localhost:8000
# For Railway: https://unyield-faceblur-api-production.up.railway.app
FACE_BLUR_API_URL=https://unyield-faceblur-api-production.up.railway.app
FACE_BLUR_TIMEOUT_MS=360000

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=120

# Auth endpoints (login/register) - stricter to reduce brute force attacks
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=12

# Invite actions - per-user/IP
INVITE_RATE_LIMIT_WINDOW_MS=3600000
INVITE_RATE_LIMIT_MAX_REQUESTS=30

# Safety gate for destructive maintenance scripts (reset/clean).
# Leave disabled by default.
ALLOW_DESTRUCTIVE_SCRIPTS=false
