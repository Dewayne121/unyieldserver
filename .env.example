# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Prisma)
# For Railway: Use the DATABASE_URL provided by Railway
# For local development: Use your local PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/unyielding?schema=public"

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Oracle Cloud Object Storage (for video uploads)
# ORACLE_SECRET should be a base64 encoded JSON string with your Oracle credentials
ORACLE_SECRET=

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
